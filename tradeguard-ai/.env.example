# Supabase (local dev: supabase start 출력 사용)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider — 'anthropic' (default) or 'openai'
LLM_PROVIDER=anthropic

# Anthropic Claude (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Optional: override default model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# Optional: override default model (default: gpt-4o-2024-08-06)
OPENAI_MODEL=gpt-4o-2024-08-06

# Finnhub (free tier — finnhub.io/register)
FINNHUB_API_KEY=

# PII anonymization secret — NOTE: production uses per-user `user_secrets.pii_hmac_secret`
# in Supabase (generated by ensureUserSecret on first login). This env var is read
# ONLY by `tests/helpers/setup.ts` to produce deterministic test fixtures.
# Generate: `openssl rand -hex 32`
PII_HMAC_SECRET=

# Kakao OAuth (Supabase Auth Provider 콘솔에 등록)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Cost guard (optional — daily USD cap for LLM calls)
LLM_DAILY_USD_CAP=5.00
